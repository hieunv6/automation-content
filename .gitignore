*.user
*.suo
*.userosscache
*.sln.docstates

# IDE
.vs/
.vscode/
.idea/
*.swp
*~

# NuGet
*.nupkg
**/packages/*
project.lock.json
project.fragment.lock.json
artifacts/

# macOS
.DS_Store
